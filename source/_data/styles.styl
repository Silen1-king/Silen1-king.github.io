// ========== Starry Sky Theme ==========

// --- Background ---
body
  background: linear-gradient(to bottom, #0b0d17 0%, #1a1a2e 40%, #16213e 70%, #0f3460 100%) !important
  background-attachment: fixed !important
  min-height: 100vh

// --- Main content transparency ---
.main, .header, .footer
  background: transparent !important

.main-inner
  background: rgba(10, 12, 28, 0.75) !important
  border-radius: 12px
  backdrop-filter: blur(6px)

// --- Header ---
.header
  background: rgba(10, 12, 28, 0.8) !important
  backdrop-filter: blur(8px)

.site-brand-container
  background: rgba(15, 20, 50, 0.9) !important

// --- Sidebar ---
.sidebar
  background: rgba(10, 12, 28, 0.85) !important
  backdrop-filter: blur(8px)

.sidebar-inner
  background: transparent !important

// --- Footer ---
.footer
  background: rgba(10, 12, 28, 0.6) !important

// --- Card / Post blocks ---
.post-block, .posts-collapse
  background: rgba(20, 24, 50, 0.6) !important
  border-radius: 8px
  backdrop-filter: blur(4px)

// --- Text colors ---
body, .post-body, .post-title, .post-title-link
  color: #d0d4e8 !important

.site-title
  color: #e0e4f0 !important

.sidebar a, .sidebar-nav .sidebar-nav-active
  color: #b8bcd0 !important

.sidebar-nav .sidebar-nav-active
  border-bottom-color: #7c8aff !important

.post-toc .nav-item a
  color: #a0a4c0 !important

  &:hover, &.active
    color: #7c8aff !important

// --- Links ---
a, .post-title-link
  color: #7c8aff !important

  &:hover
    color: #a78bfa !important

// --- Code blocks ---
.highlight, pre
  background: rgba(15, 18, 40, 0.9) !important

code
  background: rgba(100, 110, 200, 0.15) !important
  color: #c0c4f0 !important

// --- Tables ---
table
  border-color: rgba(100, 110, 200, 0.2) !important

th
  background: rgba(30, 34, 70, 0.8) !important
  color: #d0d4e8 !important

td
  border-color: rgba(100, 110, 200, 0.15) !important

// --- Blockquote ---
blockquote
  border-left-color: #7c8aff !important
  background: rgba(30, 34, 70, 0.4) !important
  color: #b0b4d0 !important

// --- Pagination ---
.pagination .page-number, .pagination .extend
  background: rgba(30, 34, 70, 0.6) !important
  color: #b0b4d0 !important
  border-color: rgba(100, 110, 200, 0.2) !important

  &:hover, &.current
    background: rgba(100, 110, 200, 0.3) !important
    color: #e0e4f0 !important

// --- Search popup ---
.popular-posts, .search-result-container
  background: rgba(15, 18, 45, 0.95) !important

.search-result-container .search-result-list .search-result-item
  border-bottom-color: rgba(100, 110, 200, 0.15) !important

// --- Back to top ---
.back-to-top
  background: rgba(100, 110, 200, 0.3) !important
  color: #d0d4e8 !important

  &:hover
    background: rgba(100, 110, 200, 0.5) !important

// --- Scrollbar ---
::-webkit-scrollbar
  width: 8px
  background: rgba(10, 12, 28, 0.5)

::-webkit-scrollbar-thumb
  background: rgba(100, 110, 200, 0.4)
  border-radius: 4px

  &:hover
    background: rgba(100, 110, 200, 0.6)

// --- Tag cloud ---
.tag-cloud-tags a
  color: #7c8aff !important

  &:hover
    color: #a78bfa !important

// --- Category list ---
.category-list-item .category-list-link
  color: #7c8aff !important

// --- Post meta ---
.post-meta
  color: #8084a0 !important

// --- Headband (top bar) ---
.headband
  background: linear-gradient(90deg, #7c8aff, #a78bfa, #7c8aff) !important
  height: 3px !important

// --- Menu hover effect ---
.menu-item a:hover
  background: rgba(100, 110, 200, 0.15) !important

// --- Canvas stars overlay ---
#stars-canvas
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  z-index: -1
  pointer-events: none

// --- Instant Search ---
@import 'instant-search.styl'

// ========== Search Popup Occlusion Fix ==========

// 1. Force parent containers to allow overflow for dropdown visibility
.header,
.header-inner,
.site-brand-container,
.site-nav {
    overflow: visible !important;
}

// 2. Fix search popup z-index and add floating visual enhancement
.search-popup,
.local-search-popup,
.search-result-container {
    z-index: 9999 !important;
}

// 3. Fix search input box visibility — increase contrast against header
.instant-search-input {
    background: rgba(25, 30, 60, 0.95) !important;
    border: 2px solid rgba(124, 138, 255, 0.55) !important;
    box-shadow: 0 0 12px rgba(124, 138, 255, 0.15) !important;
}

.instant-search-input:focus {
    border-color: #7c8aff !important;
    box-shadow: 0 0 24px rgba(124, 138, 255, 0.35) !important;
    background: rgba(20, 24, 55, 0.98) !important;
}

// 4. Make search results panel fully opaque (no transparency)
.instant-search-results {
    background: rgb(10, 14, 35) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
}

.instant-search-overlay {
    background: rgba(0, 0, 0, 0.5) !important;
    backdrop-filter: none !important;
    -webkit-backdrop-filter: none !important;
}

// ========== Learning Paths / Series ==========

.learning-paths-intro
  margin: 0 0 28px
  padding: 22px 24px
  border: 1px solid rgba(124, 138, 255, .22)
  border-radius: 12px
  background: rgba(20, 24, 50, .58)

  p
    margin: 0 0 14px
    color: #c9cee7

.learning-paths-stats
  display: flex
  flex-wrap: wrap
  gap: 12px

  span
    padding: 6px 12px
    border-radius: 999px
    background: rgba(124, 138, 255, .14)
    color: #bfc5ee
    font-size: .9em

  strong
    color: #a9b2ff

.learning-path-grid
  display: grid
  grid-template-columns: repeat(2, minmax(0, 1fr))
  gap: 22px

.learning-path-card
  padding: 0 22px 20px
  overflow: hidden
  border: 1px solid rgba(124, 138, 255, .2)
  border-radius: 14px
  background: linear-gradient(145deg, rgba(24, 29, 61, .9), rgba(13, 17, 40, .82))
  box-shadow: 0 12px 30px rgba(0, 0, 0, .2)
  transition: transform .25s ease, border-color .25s ease

  &:hover
    transform: translateY(-3px)
    border-color: rgba(124, 138, 255, .5)

.learning-path-card-header
  display: flex
  align-items: center
  gap: 14px
  margin: 0 -22px 18px
  padding: 20px 22px
  border-bottom: 1px solid rgba(124, 138, 255, .16)
  background: rgba(124, 138, 255, .07)

  h2
    margin: 0 0 3px
    color: #e0e4f6
    font-size: 1.22em
    line-height: 1.35

.learning-path-card-index
  flex: 0 0 auto
  color: #7c8aff
  font-size: 1.55em
  font-weight: 700
  letter-spacing: .04em

.learning-path-card-count
  color: #8f96b8
  font-size: .82em

.learning-path-steps
  margin: 0 !important
  padding: 0 !important
  list-style: none !important

.learning-path-step
  position: relative
  display: flex
  gap: 14px
  padding: 0 0 20px

  &:not(:last-child)::before
    content: ''
    position: absolute
    top: 27px
    bottom: 1px
    left: 13px
    width: 1px
    background: linear-gradient(rgba(124, 138, 255, .55), rgba(124, 138, 255, .12))

  &:last-child
    padding-bottom: 0

.learning-path-step-number
  position: relative
  z-index: 1
  display: flex
  flex: 0 0 28px
  align-items: center
  justify-content: center
  width: 28px
  height: 28px
  border: 1px solid rgba(124, 138, 255, .55)
  border-radius: 50%
  background: #171c3d
  color: #aab3ff
  font-size: .76em
  font-weight: 700

.learning-path-step-content
  min-width: 0
  padding-top: 2px

.learning-path-step-title
  display: block
  border: 0 !important
  color: #cbd0f2 !important
  font-weight: 600
  line-height: 1.5

  &:hover
    color: #a78bfa !important

.learning-path-step-date
  display: block
  margin-top: 3px
  color: #747c9d
  font-size: .75em

.learning-path-step-description
  margin: 7px 0 0 !important
  color: #969dbc
  font-size: .86em
  line-height: 1.65

.learning-paths-empty
  grid-column: 1 / -1
  padding: 28px
  text-align: center

@media (max-width: 767px)
  .learning-path-grid
    grid-template-columns: 1fr

  .learning-paths-intro
    padding: 18px

  .learning-path-card
    padding-right: 18px
    padding-left: 18px

  .learning-path-card-header
    margin-right: -18px
    margin-left: -18px
    padding-right: 18px
    padding-left: 18px

// ========== Article Rendering Enhancements ==========

// GitHub / Obsidian-style Markdown alerts.
.markdown-alert
  --alert-color: #7c8aff
  margin: 24px 0
  padding: 16px 18px
  border: 1px solid rgba(124, 138, 255, .28)
  border-left: 4px solid var(--alert-color)
  border-radius: 10px
  background: rgba(20, 24, 50, .7)
  box-shadow: 0 8px 24px rgba(0, 0, 0, .14)

  p
    margin: 8px 0

  .markdown-alert-title
    display: flex
    align-items: center
    gap: 8px
    margin: 0 0 8px
    color: var(--alert-color)
    font-weight: 700

  .markdown-alert-body > :first-child
    margin-top: 0

  .markdown-alert-body > :last-child
    margin-bottom: 0

.markdown-alert-note
  --alert-color: #74a7ff

.markdown-alert-tip
  --alert-color: #58d6a7

.markdown-alert-important
  --alert-color: #a78bfa

.markdown-alert-warning
  --alert-color: #f6bd60

.markdown-alert-caution
  --alert-color: #ff758f

// Old-article freshness notice.
.post-stale-notice
  display: flex
  align-items: flex-start
  gap: 12px
  margin: 0 0 26px
  padding: 15px 18px
  border: 1px solid rgba(246, 189, 96, .42)
  border-radius: 10px
  background: linear-gradient(135deg, rgba(246, 189, 96, .14), rgba(255, 117, 143, .07))
  color: #e7d6ad

  p
    margin: 0
    line-height: 1.7

.post-stale-notice-icon
  flex: 0 0 auto
  font-size: 1.18em

// Fallback toolbar for plain pre/code and Prism output.
.post-code-container
  position: relative
  margin: 20px 0
  overflow: hidden
  border-radius: 6px

  > pre
    margin: 0 !important
    padding-top: 38px !important

.post-copy-btn
  border: 0
  font: inherit
  cursor: pointer

.post-body .code-lang
  max-width: calc(100% - 54px)
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

// Metadata-based related posts at the end of each article.
.related-posts-section
  margin-top: 52px
  padding-top: 30px
  border-top: 1px solid rgba(124, 138, 255, .2)

.related-posts-heading
  margin-bottom: 18px

  h2
    margin: 3px 0 0
    color: #e1e5f5
    font-size: 1.35em

.related-posts-kicker
  color: #7c8aff
  font-size: .72em
  font-weight: 700
  letter-spacing: .14em

.related-posts-grid
  display: grid
  grid-template-columns: repeat(3, minmax(0, 1fr))
  gap: 14px

.related-post-card
  position: relative
  display: flex
  min-width: 0
  min-height: 145px
  flex-direction: column
  padding: 17px
  border: 1px solid rgba(124, 138, 255, .2) !important
  border-radius: 11px
  background: linear-gradient(145deg, rgba(25, 30, 62, .82), rgba(14, 18, 42, .78))
  color: #cdd2ed !important
  text-decoration: none
  transition: transform .22s ease, border-color .22s ease, box-shadow .22s ease

  &:hover
    transform: translateY(-3px)
    border-color: rgba(124, 138, 255, .52) !important
    box-shadow: 0 12px 26px rgba(0, 0, 0, .2)

  h3
    margin: 9px 0 12px
    color: #dce0f4
    font-size: .98em
    line-height: 1.55

  time
    margin-top: auto
    color: #757d9e
    font-size: .74em

.related-post-reason
  overflow: hidden
  color: #929af0
  font-size: .72em
  line-height: 1.45
  text-overflow: ellipsis
  white-space: nowrap

.related-post-arrow
  position: absolute
  right: 15px
  bottom: 13px
  color: #7c8aff

@media (max-width: 900px)
  .related-posts-grid
    grid-template-columns: 1fr

  .related-post-card
    min-height: 120px

@media (max-width: 767px)
  .markdown-alert, .post-stale-notice
    padding: 14px

  .related-posts-section
    margin-top: 40px

// ========== Archive Accordion & Blog Stats ==========

.archive-accordion .archive-block
  padding: 30px

.archive-page-header
  margin-bottom: 28px
  text-align: center

  h1
    margin: 4px 0 8px
    color: #e2e6f5

  p
    margin: 0
    color: #858dab

.archive-page-kicker
  color: #7c8aff
  font-size: .74em
  font-weight: 700
  letter-spacing: .16em

.archive-tree
  display: grid
  gap: 16px

.archive-year,
.archive-month
  overflow: hidden
  border: 1px solid rgba(124, 138, 255, .2)
  border-radius: 12px
  background: rgba(17, 21, 46, .68)

  > summary
    display: flex
    align-items: center
    justify-content: space-between
    cursor: pointer
    list-style: none

    &::-webkit-details-marker
      display: none

    &::after
      content: '+'
      width: 25px
      margin-left: 12px
      color: #7c8aff
      font-size: 1.2em
      text-align: center
      transition: transform .2s ease

  &[open] > summary::after
    transform: rotate(45deg)

.archive-year > summary
  padding: 18px 20px
  background: linear-gradient(90deg, rgba(124, 138, 255, .14), rgba(124, 138, 255, .03))

.archive-year-name
  margin-right: auto
  color: #dfe3f5
  font-size: 1.35em
  font-weight: 700

.archive-panel-count
  color: #8189aa
  font-size: .8em

.archive-months
  display: grid
  gap: 10px
  padding: 14px

.archive-month
  border-radius: 9px
  background: rgba(10, 14, 34, .56)

  > summary
    padding: 12px 15px

.archive-month-name
  margin-right: auto
  color: #bfc5e3
  font-weight: 600

.archive-post-list
  margin: 0 !important
  padding: 0 16px 12px !important
  list-style: none !important

  li
    display: grid
    grid-template-columns: 58px minmax(0, 1fr)
    gap: 12px
    align-items: baseline
    padding: 10px 4px
    border-top: 1px solid rgba(124, 138, 255, .1)

  time
    color: #747c9e
    font-size: .78em
    font-variant-numeric: tabular-nums

  a
    overflow: hidden
    color: #c6cbe7 !important
    text-overflow: ellipsis
    white-space: nowrap

    &:hover
      color: #a78bfa !important

.sidebar-tech-stats
  margin: 22px 12px 0
  padding: 16px
  border: 1px solid rgba(124, 138, 255, .2)
  border-radius: 11px
  background: rgba(20, 24, 50, .5)
  text-align: left

  h2
    margin: 0 0 10px
    color: #cfd4eb
    font-size: .94em

.sidebar-stats-summary
  margin: 0 0 15px
  color: #9299b9
  font-size: .78em
  line-height: 1.65

  strong
    color: #aeb6ff

.sidebar-tag-bars
  display: grid
  gap: 9px

.sidebar-tag-meta
  display: flex
  justify-content: space-between
  margin-bottom: 4px
  color: #9da4c4
  font-size: .7em

.sidebar-tag-track
  height: 5px
  overflow: hidden
  border-radius: 999px
  background: rgba(124, 138, 255, .11)

  span
    display: block
    height: 100%
    border-radius: inherit
    background: linear-gradient(90deg, #6e7df0, #a78bfa)

@media (max-width: 767px)
  .archive-accordion .archive-block
    padding: 20px 14px

  .archive-year > summary
    padding: 15px

  .archive-months
    padding: 10px

  .archive-post-list li
    grid-template-columns: 48px minmax(0, 1fr)
    gap: 8px

// ========== Visitor Experience Pass ==========

html
  color-scheme: dark

:focus-visible
  outline: 3px solid #aeb6ff !important
  outline-offset: 3px

.column,
.site-nav
  background: rgba(8, 11, 28, .96) !important

.site-brand-container
  align-items: center
  gap: 12px

.site-meta
  min-width: 0

.site-title
  overflow: hidden
  text-overflow: ellipsis
  white-space: nowrap

.site-nav-right
  display: flex !important
  flex: 0 0 auto
  align-items: center

.site-nav-toggle .toggle
  box-sizing: border-box
  width: 44px
  height: 44px
  padding: 11px
  border: 0
  background: transparent
  cursor: pointer

.main-menu .menu-item a
  min-height: 40px
  align-content: center

// A concise orientation layer before the chronological post feed.
.home-hero
  display: grid
  grid-template-columns: minmax(0, 1.4fr) minmax(220px, .6fr)
  gap: 28px
  margin: 34px 0 46px
  padding: 34px
  overflow: hidden
  border: 1px solid rgba(124, 138, 255, .3)
  border-radius: 18px
  background: radial-gradient(circle at 85% 10%, rgba(124, 138, 255, .2), transparent 35%), linear-gradient(145deg, rgba(24, 29, 61, .96), rgba(10, 14, 35, .92))
  box-shadow: 0 20px 60px rgba(0, 0, 0, .26)

.home-hero-kicker
  display: inline-block
  margin-bottom: 12px
  color: #9ba6ff
  font-size: .76em
  font-weight: 700
  letter-spacing: .14em

.home-hero h1
  max-width: 680px
  margin: 0
  color: #f2f4ff
  font-size: clamp(1.65em, 3.4vw, 2.5em)
  line-height: 1.3
  text-align: left

.home-hero-copy > p
  max-width: 650px
  margin: 18px 0 24px
  color: #bac1df
  line-height: 1.8

.home-hero-actions
  display: flex
  flex-wrap: wrap
  gap: 12px

.home-hero-search,
.home-hero-primary
  display: inline-flex
  min-height: 46px
  box-sizing: border-box
  align-items: center
  justify-content: center
  gap: 9px
  padding: 10px 16px
  border-radius: 10px
  font: inherit
  font-weight: 600
  cursor: pointer

.home-hero-search
  border: 1px solid rgba(124, 138, 255, .55)
  background: #727ff0
  color: #fff

  kbd
    margin-left: 6px
    padding: 2px 6px
    border: 1px solid rgba(255, 255, 255, .3)
    border-radius: 5px
    background: rgba(0, 0, 0, .14)
    color: #fff
    font-size: .72em

.home-hero-primary
  border: 1px solid rgba(124, 138, 255, .32) !important
  background: rgba(124, 138, 255, .09)
  color: #d8dcff !important
  text-decoration: none

.home-hero-map
  display: grid
  align-content: center
  gap: 10px

  a
    display: grid
    grid-template-columns: 32px minmax(0, 1fr)
    gap: 2px 10px
    min-height: 58px
    box-sizing: border-box
    align-content: center
    padding: 10px 12px
    border: 1px solid rgba(124, 138, 255, .18) !important
    border-radius: 10px
    background: rgba(7, 10, 28, .42)
    color: #dce0fa !important
    text-decoration: none

    &:hover
      border-color: rgba(124, 138, 255, .55) !important
      background: rgba(124, 138, 255, .12)

    span
      grid-row: 1 / 3
      align-self: center
      color: #7f8cff
      font-size: .78em
      font-weight: 700

    strong
      line-height: 1.3

    small
      color: #858eaf
      font-size: .72em

.home-latest-heading
  display: flex
  align-items: baseline
  gap: 10px
  margin: 0 0 -18px

  span
    color: #7c8aff
    font-size: .7em
    font-weight: 700
    letter-spacing: .14em

  strong
    color: #dce0f4
    font-size: 1.05em

// Keep code usable on narrow screens and make controls touch-friendly.
.post-body figure.highlight,
.post-body .post-code-container
  max-width: 100%
  box-sizing: border-box
  border: 1px solid rgba(124, 138, 255, .2)
  border-radius: 10px
  overscroll-behavior-inline: contain
  scrollbar-color: rgba(142, 153, 255, .58) rgba(8, 11, 28, .6)

.post-body figure.highlight > .code-container
  padding-top: 38px

.post-body figure.highlight .table-container,
.post-body pre
  overflow-x: auto

.post-body pre
  max-width: 100%
  tab-size: 2

.post-body .code-lang
  top: 9px !important
  right: 54px !important
  max-width: calc(100% - 112px)
  padding: 4px 8px
  border: 1px solid rgba(124, 138, 255, .2)
  border-radius: 999px
  background: rgba(124, 138, 255, .1)
  color: #aeb6dc
  font-size: 11px !important
  font-weight: 700
  line-height: 1.2 !important
  letter-spacing: .06em
  opacity: 1 !important

.post-body .copy-btn
  z-index: 4
  display: inline-flex
  min-width: 44px
  min-height: 38px
  box-sizing: border-box
  align-items: center
  justify-content: center
  padding: 8px 11px
  border: 0
  border-radius: 0 9px 0 9px
  background: rgba(30, 36, 73, .98) !important
  color: #d8dcf3 !important
  opacity: .82

  &:hover,
  &:focus-visible
    background: #6876df !important
    color: #fff !important
    opacity: 1

// Give deep headings a visual hierarchy in older, densely nested articles.
.post-body h4
  padding-left: 11px
  border-left: 3px solid #7c8aff
  color: #dce1f6
  font-size: 1.12em

.post-body h5
  position: relative
  padding-left: 16px
  color: #bec5e4
  font-size: 1em

  &::before
    content: ''
    position: absolute
    top: .7em
    left: 0
    width: 6px
    height: 6px
    border-radius: 50%
    background: #8d98ff

.post-body h6
  color: #9da6ca
  font-size: .94em
  letter-spacing: .04em

// The TOC must scroll inside the viewport instead of covering the article.
.sidebar
  max-width: calc(100vw - 56px)

.sidebar-inner
  max-height: 100dvh
  overflow-y: auto
  overscroll-behavior: contain

.post-toc-wrap
  max-height: calc(100dvh - 150px)
  overflow-y: auto
  scrollbar-width: thin

.post-toc .nav-item
  overflow-wrap: anywhere
  white-space: normal !important

.sidebar-toggle
  box-sizing: border-box
  border: 0

.sidebar-toggle-icon
  display: block
  width: 20px

// Native lazy loading is added during generation; this is the local zoom UI.
.post-image-zoomable
  border-radius: 8px
  cursor: zoom-in

.image-zoom-overlay
  position: fixed
  inset: 0
  z-index: 2147483646
  display: grid
  place-items: center
  padding: 24px
  background: rgba(2, 4, 14, .92)
  opacity: 0
  transition: opacity .18s ease

  &[hidden]
    display: none !important

  &.is-open
    opacity: 1

.image-zoom-figure
  display: grid
  max-width: min(94vw, 1440px)
  max-height: 92dvh
  margin: 0
  place-items: center

  img
    max-width: 100%
    max-height: calc(92dvh - 44px)
    object-fit: contain
    box-shadow: 0 24px 80px rgba(0, 0, 0, .58)

  figcaption
    margin-top: 10px
    color: #c5cbe8
    text-align: center

.image-zoom-close
  position: fixed
  top: calc(14px + env(safe-area-inset-top))
  right: calc(14px + env(safe-area-inset-right))
  z-index: 1
  width: 44px
  height: 44px
  padding: 0
  border: 1px solid rgba(255, 255, 255, .28)
  border-radius: 50%
  background: rgba(20, 24, 50, .92)
  color: #fff
  font-size: 1.7em
  line-height: 1
  cursor: pointer

body.image-zoom-open
  overflow: hidden

@media (any-hover: none), (pointer: coarse)
  .post-body .copy-btn
    min-height: 44px
    opacity: 1

@media (max-width: 767px)
  .site-brand-container
    gap: 4px
    padding: 0 10px

  .site-nav-toggle,
  .site-nav-right
    flex: 0 0 44px

  .site-nav-right
    flex-direction: row

  .site-title
    font-size: 1.35em

  .site-subtitle
    display: none

  .global-search-trigger
    width: 44px
    min-width: 44px
    height: 44px
    justify-content: center
    padding: 0

  .main-menu .menu-item a
    min-height: 44px
    padding: 0 12px

  .home-hero
    grid-template-columns: 1fr
    gap: 22px
    margin: 20px 0 34px
    padding: 23px 19px
    border-radius: 14px

  .home-hero h1
    font-size: clamp(1.48em, 8vw, 2em)

  .home-hero-copy > p
    margin: 14px 0 20px

  .home-hero-actions
    display: grid
    grid-template-columns: 1fr

  .home-hero-search,
  .home-hero-primary
    width: 100%

  .home-hero-map
    grid-template-columns: 1fr

  .home-latest-heading
    margin-bottom: -8px

  .post-body figure.highlight
    margin-right: -4px
    margin-left: -4px

  .sidebar-toggle
    display: flex
    width: auto
    min-width: 76px
    height: 44px
    align-items: center
    gap: 9px
    padding: 0 12px
    border-radius: 8px
    color: #e1e5f7

    &::after
      content: attr(data-label)
      font-size: 13px
      font-weight: 600

@media (prefers-reduced-motion: reduce)
  .home-hero *,
  .related-post-card,
  .learning-path-card,
  .image-zoom-overlay
    scroll-behavior: auto !important
    transition: none !important
