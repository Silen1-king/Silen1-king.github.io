/* Full-screen local search modal */

.global-search-trigger {
  display: inline-flex;
  align-items: center;
  gap: 9px;
  min-width: 180px;
  padding: 10px 12px 10px 16px;
  border: 1px solid rgba(124, 138, 255, .32);
  border-radius: 22px;
  background: rgba(20, 24, 50, .82);
  color: #aeb4d4;
  font: inherit;
  cursor: pointer;
  backdrop-filter: blur(8px);
  transition: border-color .2s ease, box-shadow .2s ease, color .2s ease;
}

.global-search-trigger:hover,
.global-search-trigger:focus-visible {
  border-color: rgba(124, 138, 255, .7);
  color: #e0e4f4;
  box-shadow: 0 0 20px rgba(124, 138, 255, .18);
  outline: none;
}

.global-search-trigger kbd {
  margin-left: auto;
}

.global-search-modal[hidden] {
  display: none !important;
}

.global-search-modal {
  position: fixed;
  inset: 0;
  z-index: 2147483647;
  display: grid;
  place-items: start center;
  padding: min(11vh, 96px) 18px 24px;
  opacity: 0;
  transition: opacity .18s ease;
}

.global-search-modal.is-open {
  opacity: 1;
}

.global-search-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(2, 5, 18, .74);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.global-search-panel {
  position: relative;
  display: flex;
  width: min(860px, 96vw);
  max-height: min(76vh, 720px);
  overflow: hidden;
  flex-direction: column;
  border: 1px solid rgba(124, 138, 255, .32);
  border-radius: 17px;
  background: rgb(10, 14, 35);
  box-shadow: 0 28px 90px rgba(0, 0, 0, .58), 0 0 55px rgba(124, 138, 255, .1);
  transform: translateY(-12px) scale(.985);
  transition: transform .2s ease;
}

.global-search-modal.is-open .global-search-panel {
  transform: translateY(0) scale(1);
}

.global-search-header {
  display: flex;
  align-items: center;
  gap: 13px;
  padding: 17px 20px;
  border-bottom: 1px solid rgba(124, 138, 255, .18);
}

.global-search-header > i {
  color: #7c8aff;
  font-size: 1.1em;
}

.global-search-label {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
}

.global-search-input {
  min-width: 0;
  flex: 1;
  padding: 3px 0;
  border: 0;
  background: transparent;
  color: #edf0ff;
  font: inherit;
  font-size: 1.08em;
  outline: none;
}

.global-search-input::placeholder {
  color: #6f7697;
}

.global-search-input::-webkit-search-cancel-button {
  display: none;
}

.global-search-close {
  width: 31px;
  height: 31px;
  padding: 0;
  border: 1px solid rgba(124, 138, 255, .2);
  border-radius: 8px;
  background: rgba(124, 138, 255, .08);
  color: #9da4c7;
  font-size: 1.35em;
  line-height: 1;
  cursor: pointer;
}

.global-search-close:hover {
  color: #fff;
}

.global-search-status {
  padding: 10px 20px;
  border-bottom: 1px solid rgba(124, 138, 255, .1);
  color: #7f87aa;
  font-size: .78em;
}

.global-search-results {
  min-height: 170px;
  margin: 0;
  padding: 8px;
  overflow-y: auto;
  list-style: none;
}

.global-search-results::-webkit-scrollbar {
  width: 8px;
}

.global-search-results::-webkit-scrollbar-thumb {
  border-radius: 4px;
  background: rgba(124, 138, 255, .3);
}

.global-search-result {
  margin: 3px 0;
  border-radius: 11px;
}

.global-search-result.is-active,
.global-search-result:hover {
  background: rgba(124, 138, 255, .1);
}

.global-search-result-link {
  position: relative;
  display: block;
  padding: 15px 45px 15px 16px;
  border: 1px solid transparent !important;
  border-radius: 11px;
  color: inherit !important;
  text-decoration: none;
}

.global-search-result.is-active .global-search-result-link {
  border-color: rgba(124, 138, 255, .24) !important;
}

.global-search-result h3 {
  margin: 0 0 8px;
  color: #e0e4f4;
  font-size: 1em;
  line-height: 1.45;
}

.global-search-result p {
  display: -webkit-box;
  margin: 8px 0 0;
  overflow: hidden;
  color: #9299b9;
  font-size: .84em;
  line-height: 1.65;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.global-search-result > a > i {
  position: absolute;
  top: 19px;
  right: 17px;
  color: #626a8e;
  transition: color .2s ease, transform .2s ease;
}

.global-search-result.is-active > a > i,
.global-search-result:hover > a > i {
  color: #8d98ff;
  transform: translateX(3px);
}

.global-search-result-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}

.global-search-result-meta span {
  padding: 3px 7px;
  border-radius: 999px;
  background: rgba(124, 138, 255, .1);
  color: #aab0d2;
  font-size: .7em;
}

.global-search-result-meta small {
  margin-right: 4px;
  color: #697195;
}

.global-search-result mark {
  padding: 0 2px;
  border-radius: 3px;
  background: rgba(246, 189, 96, .3);
  color: #ffe1a0;
}

.global-search-empty {
  display: grid;
  min-height: 160px;
  place-content: center;
  color: #71799c;
  text-align: center;
}

.global-search-empty i {
  margin-bottom: 8px;
  font-size: 1.5em;
}

.global-search-empty p {
  margin: 0;
}

.global-search-footer {
  display: flex;
  gap: 18px;
  padding: 10px 18px;
  border-top: 1px solid rgba(124, 138, 255, .14);
  color: #6f7697;
  font-size: .72em;
}

.global-search-footer span {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

.global-search-trigger kbd,
.global-search-footer kbd {
  padding: 2px 6px;
  border: 1px solid rgba(124, 138, 255, .24);
  border-radius: 5px;
  background: rgba(124, 138, 255, .09);
  color: #8e96b9;
  font-family: inherit;
  font-size: .75em;
  box-shadow: none;
}

body.global-search-open {
  overflow: hidden;
}

@media (max-width: 767px) {
  .global-search-trigger {
    min-width: auto;
    padding: 10px 13px;
  }

  .global-search-trigger span,
  .global-search-trigger kbd {
    display: none;
  }

  .global-search-modal {
    padding: 10px;
  }

  .global-search-panel {
    width: 100%;
    max-height: calc(100vh - 20px);
    border-radius: 13px;
  }

  .global-search-footer {
    display: none;
  }
}

@media (prefers-reduced-motion: reduce) {
  .global-search-modal,
  .global-search-panel {
    transition: none;
  }
}
