{% extends '_layout.njk' %}
{% import '_macro/sidebar.njk' as sidebar_template with context %}

{% block title %}{{ __('title.archive') }} | {{ title }}{% endblock %}

{% block class %}archive archive-accordion{% endblock %}

{% block content %}
  <div class="post-block archive-block">
    <div class="post-content">
      <header class="archive-page-header">
        <span class="archive-page-kicker">ARCHIVE</span>
        <h1>文章归档</h1>
        <p>共收录 {{ page.posts.length }} 篇文章，按年份与月份浏览。</p>
      </header>
      <div class="archive-tree">
        {{ archive_tree(page.posts) }}
      </div>
    </div>
  </div>
{% endblock %}

{% block sidebar %}
  {{ sidebar_template.render(false) }}
{% endblock %}
