<div class="site-brand-container">
  <div class="site-nav-toggle">
    <div class="toggle" aria-label="{{ __('accessibility.nav_toggle') }}" role="button">
      {%- if theme.menu %}
        <span class="toggle-line"></span>
        <span class="toggle-line"></span>
        <span class="toggle-line"></span>
      {%- endif %}
    </div>
  </div>

  <div class="site-meta">
    {%- if theme.custom_logo and theme.scheme === 'Muse' %}
      <img class="custom-logo-image" src="{{ url_for(theme.custom_logo) }}" alt="{{ title }}">
    {%- endif %}

    <a href="{{ config.root }}" class="brand" rel="start">
      <i class="logo-line"></i>
      <{% if is_home() or is_archive() %}h1{% else %}p{% endif %} class="site-title">{{ title }}</{% if is_home() or is_archive() %}h1{% else %}p{% endif %}>
      <i class="logo-line"></i>
    </a>
    {%- if subtitle %}
      <p class="site-subtitle" itemprop="description">{{ subtitle }}</p>
    {%- endif %}
    {%- if theme.custom_logo and (theme.scheme === 'Gemini' or theme.scheme === 'Pisces') %}
      <img class="custom-logo-image" src="{{ url_for(theme.custom_logo) }}" alt="{{ title }}">
    {%- endif %}
  </div>

  <div class="site-nav-right">
    {%- if theme.local_search.enable %}
      <button class="global-search-trigger" type="button" aria-haspopup="dialog" aria-controls="global-search-modal">
        <i class="fa fa-search" aria-hidden="true"></i><span>搜索</span><kbd>Ctrl K</kbd>
      </button>
      <div id="global-search-modal" class="global-search-modal" role="dialog" aria-modal="true" aria-labelledby="global-search-title" aria-hidden="true" hidden>
        <div class="global-search-backdrop" data-search-close></div>
        <section class="global-search-panel">
          <header class="global-search-header">
            <i class="fa fa-search" aria-hidden="true"></i>
            <label id="global-search-title" class="global-search-label" for="global-search-input">全站搜索</label>
            <input id="global-search-input" class="global-search-input" type="search" placeholder="搜索标题、标签、分类和正文…" autocomplete="off" spellcheck="false">
            <button class="global-search-close" type="button" data-search-close aria-label="关闭搜索">×</button>
          </header>
          <div class="global-search-status" role="status" aria-live="polite">输入关键词开始检索</div>
          <ul class="global-search-results" role="listbox"></ul>
          <footer class="global-search-footer">
            <span><kbd>↑</kbd><kbd>↓</kbd> 选择</span><span><kbd>Enter</kbd> 打开</span><span><kbd>Esc</kbd> 关闭</span>
          </footer>
        </section>
      </div>
    {%- else %}
      <div class="toggle popup-trigger" aria-label="{{ __('menu.search') }}" role="button">
        {%- if theme.algolia_search.enable or theme.local_search.enable %}
          <i class="fa fa-search fa-fw fa-lg"></i>
        {%- endif %}
      </div>
    {%- endif %}
  </div>
</div>
